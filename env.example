# Environment Configuration for AI Triage Assistant

# Database Configuration
DATABASE_URL=sqlite:///./triage_surveillance.db
REDIS_URL=redis://localhost:6379

# LangChain Configuration
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=triage-assistant
LANGCHAIN_TRACING=true

# Model Configuration
MODEL_NAME=ali009eng/llama-8b-mimic-ed-triage
MODEL_CACHE_DIR=./models

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# MIMIC-IV-ED Dataset Path
MIMIC_DATA_PATH=./data/mimic_iv_ed

# Vector Database Path
VECTOR_DB_PATH=./data/vector_db

# Surveillance Configuration
SURVEILLANCE_WINDOW_HOURS=24
OUTBREAK_THRESHOLD=0.8
CLUSTER_MIN_SIZE=5

# Dashboard Configuration
DASHBOARD_REFRESH_INTERVAL=30
MAX_PATIENTS_DISPLAY=50

# Logging Configuration
LOG_LEVEL=INFO

